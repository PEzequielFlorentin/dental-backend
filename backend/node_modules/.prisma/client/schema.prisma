// ==============================
// ENUMS
// ==============================
enum TipoCliente {
  ODONTOLOGO
  CLINICA_DENTAL
  PARTICULAR
  LABORATORIO
  OTRO
}

enum RolUsuario {
  ADMIN
  SUPER_ADMIN
}

// ==============================
// ADMINISTRADOR
// ==============================
model administrador {
  id            Int      @id @default(autoincrement())
  nombre        String   @db.VarChar(100)
  telefono      String?  @db.VarChar(20)
  email         String?  @unique @db.VarChar(100)
  usuario       String   @unique @db.VarChar(50)
  super_usuario Boolean? @default(false)

  // Autenticación
  password               String    @db.VarChar(255)
  rol                    String    @default("ADMIN")
  reset_password_token   String?   @unique @db.VarChar(255)
  reset_password_expires DateTime?

  // Auditoría
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt
  last_login     DateTime?
  login_attempts Int       @default(0)
  locked_until   DateTime?

  // Relaciones
  clientes   cliente[]
  productos  producto[]
  pedidos    pedidos[]
  pagos      pago[]
  auditorias auditoria[]
  tokens     reset_token[]

  @@index([email])
  @@index([usuario])
  @@map("administrador")
}

// ==============================
// TIPO CLIENTE
// ==============================
model tipo_cliente {
  id           Int       @id @default(autoincrement())
  descripcion  String    @db.VarChar(50)
  fecha_insert DateTime? @default(now())
  fecha_delete DateTime?

  clientes cliente[]

  @@map("tipo_cliente")
}

// ==============================
// CLIENTE
// ==============================
model cliente {
  id               Int     @id @default(autoincrement())
  id_tipo          Int?
  nombre           String  @db.VarChar(100)
  telefono         String? @db.VarChar(20)
  celular          String? @db.VarChar(20)
  email            String? @db.VarChar(100)
  id_administrador Int?

  administrador administrador? @relation(fields: [id_administrador], references: [id])
  tipo_cliente  tipo_cliente?  @relation(fields: [id_tipo], references: [id])
  pedidos       pedidos[]

  @@index([id])
  @@map("cliente")
}

// ==============================
// PRODUCTO
// ==============================
model producto {
  id               Int     @id @default(autoincrement())
  tipo             String  @db.VarChar(50)
  valor            Decimal @db.Decimal(10, 2)
  id_administrador Int?

  administrador   administrador?    @relation(fields: [id_administrador], references: [id])
  detalle_pedidos detalle_pedidos[]

  @@index([id])
  @@map("producto")
}

// ==============================
// PEDIDOS
// ==============================
model pedidos {
  id               Int       @id @default(autoincrement())
  id_cliente       Int
  fecha_entrega    DateTime? @db.Date
  fecha_pedido     DateTime  @db.Date
  fecha_delete     DateTime? @db.Date
  id_administrador Int?
  descripcion      String?   @db.VarChar(500)

  cliente         cliente           @relation(fields: [id_cliente], references: [id])
  administrador   administrador?    @relation(fields: [id_administrador], references: [id])
  detalle_pedidos detalle_pedidos[]
  detalle_pago    detalle_pago[]

  @@index([id])
  @@map("pedidos")
}

// ==============================
// ESTADO
// ==============================
model estado {
  id           Int       @id @default(autoincrement())
  descripcion  String    @db.VarChar(50)
  fecha_insert DateTime? @default(now())
  fecha_delete DateTime?

  detalle_pedidos detalle_pedidos[]

  @@index([id])
  @@map("estado")
}

// ==============================
// DETALLE_PEDIDOS
// ==============================
model detalle_pedidos {
  id              Int     @id @default(autoincrement())
  id_pedido       Int
  id_producto     Int
  cantidad        Int
  precio_unitario Decimal @db.Decimal(10, 2)
  paciente        String? @db.VarChar(100)
  id_estado       Int?

  pedido   pedidos  @relation(fields: [id_pedido], references: [id])
  producto producto @relation(fields: [id_producto], references: [id])
  estado   estado?  @relation(fields: [id_estado], references: [id])

  @@index([id])
  @@map("detalle_pedidos")
}

// ==============================
// PAGO
// ==============================
model pago {
  id               Int     @id @default(autoincrement())
  valor            Decimal @db.Decimal(10, 2)
  id_administrador Int?

  administrador administrador? @relation(fields: [id_administrador], references: [id])
  detalle_pago  detalle_pago[]

  @@index([id])
  @@map("pago")
}

// ==============================
// DETALLE_PAGO
// ==============================
model detalle_pago {
  id         Int      @id @default(autoincrement())
  id_pago    Int
  id_pedido  Int
  valor      Decimal  @db.Decimal(10, 2)
  fecha_pago DateTime @db.Date

  pago   pago    @relation(fields: [id_pago], references: [id])
  pedido pedidos @relation(fields: [id_pedido], references: [id])

  @@index([id])
  @@map("detalle_pago")
}

// ==============================
// AUDITORIA
// ==============================
model auditoria {
  id               BigInt   @id @default(autoincrement())
  id_administrador Int?
  usuario          String   @db.VarChar(50)
  fecha_accion     DateTime @default(now())
  accion           String   @db.VarChar(255)
  ip_address       String?  @db.VarChar(45)
  detalles         String?  @db.Text

  administrador administrador? @relation(fields: [id_administrador], references: [id])

  @@index([fecha_accion])
  @@map("auditoria")
}

// ==============================
// RESET TOKEN - ACTUALIZADO CON CÓDIGO
// ==============================
model reset_token {
  id               Int       @id @default(autoincrement())
  id_administrador Int
  token            String    @unique @db.VarChar(255)
  tipo             String    @default("RESET_PASSWORD")
  expires_at       DateTime
  used_at          DateTime?
  created_at       DateTime  @default(now())
  ip_address       String?   @db.VarChar(45)

  // ✅ Código de verificación de 6 dígitos
  verification_code String?   @db.VarChar(6)
  code_expires_at   DateTime?

  administrador administrador @relation(fields: [id_administrador], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([expires_at])
  @@index([verification_code])
  @@map("reset_token")
}

// ==============================
// CONFIGURACIÓN
// ==============================
model configuracion {
  id          Int      @id @default(autoincrement())
  clave       String   @unique @db.VarChar(100)
  valor       String   @db.Text
  descripcion String?  @db.VarChar(255)
  updated_at  DateTime @updatedAt

  @@map("configuracion")
}

// ==============================
// GENERATOR Y DATASOURCE
// ==============================
generator client {
  provider = "prisma-client-js"
}

datasource db {
  // ✅ CAMBIADO DE "mysql" a "postgresql" para Neon
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
