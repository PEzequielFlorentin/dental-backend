generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model administrador {
  id                      Int                @id @default(autoincrement())
  nombre                  String             @db.VarChar(100)
  telefono                String             @db.VarChar(20)
  email                   String             @unique @db.VarChar(100)
  usuario                 String             @unique @db.VarChar(50)
  super_usuario           Boolean            @default(false)
  password                String
  two_factor_enabled      Boolean            @default(false)
  two_factor_secret       String?
  two_factor_backup_codes Json?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  activo                  Boolean            @default(true)
  refreshToken            String?
  resetPasswordToken      String?
  resetPasswordExpiry     DateTime?
  clientes                cliente[]
  messages                messages[]
  otro_gastos             otro_gasto[]
  pagos                   pago[]
  pedidos                 pedidos[]
  productos               producto[]
  whatsapp_sessions       whatsapp_sessions?

  @@map("administrador")
}

model tipo_cliente {
  id           Int       @id @default(autoincrement())
  descripcion  String    @db.VarChar(50)
  fecha_insert DateTime? @default(now())
  fecha_delete DateTime?
  clientes     cliente[]

  @@map("tipo_cliente")
}

model cliente {
  id               Int           @id @default(autoincrement())
  nombre           String        @db.VarChar(100)
  telefono         String        @db.VarChar(20)
  email            String        @unique @db.VarChar(100)
  id_administrador Int
  celular          String?       @db.VarChar(20)
  id_tipo          Int?
  administrador    administrador @relation(fields: [id_administrador], references: [id])
  tipo_cliente     tipo_cliente? @relation(fields: [id_tipo], references: [id])
  messages         messages[]
  pedidos          pedidos[]

  @@index([id])
  @@index([id_administrador])
  @@index([nombre])
  @@index([telefono])
  @@index([id_tipo])
  @@map("cliente")
}

model otro_gasto {
  id               Int           @id @default(autoincrement())
  tipo             String        @db.VarChar(20)
  descripcion      String
  monto            Decimal       @db.Decimal(10, 2)
  fecha            DateTime      @default(now())
  id_administrador Int
  administrador    administrador @relation(fields: [id_administrador], references: [id])

  @@index([tipo])
  @@index([fecha])
  @@index([id_administrador])
  @@map("otro_gasto")
}

model producto {
  id               Int               @id @default(autoincrement())
  tipo             String            @db.VarChar(100)
  id_administrador Int
  detalle_pedidos  detalle_pedidos[]
  administrador    administrador     @relation(fields: [id_administrador], references: [id])

  @@index([id_administrador])
  @@index([tipo])
  @@map("producto")
}

model pedidos {
  id               Int               @id @default(autoincrement())
  id_cliente       Int
  fecha_pedido     DateTime          @default(now())
  fecha_entrega    DateTime
  fecha_delete     DateTime?
  id_administrador Int
  descripcion      String?
  detalle_pago     detalle_pago[]
  detalle_pedidos  detalle_pedidos[]
  administrador    administrador     @relation(fields: [id_administrador], references: [id])
  cliente          cliente           @relation(fields: [id_cliente], references: [id], onDelete: Cascade)

  @@index([id_cliente])
  @@index([id_administrador])
  @@index([fecha_pedido])
  @@index([fecha_entrega])
  @@index([fecha_delete])
  @@map("pedidos")
}

model estado {
  id              Int               @id @default(autoincrement())
  descripcion     String            @unique @db.VarChar(50)
  fecha_insert    DateTime          @default(now())
  fecha_delete    DateTime?
  detalle_pedidos detalle_pedidos[]

  @@index([fecha_delete])
  @@map("estado")
}

model detalle_pedidos {
  id              Int      @id @default(autoincrement())
  id_pedido       Int
  id_producto     Int
  cantidad        Int
  precio_unitario Decimal  @db.Decimal(10, 2)
  paciente        String   @db.VarChar(100)
  id_estado       Int
  estado          estado   @relation(fields: [id_estado], references: [id])
  pedido          pedidos  @relation(fields: [id_pedido], references: [id], onDelete: Cascade)
  producto        producto @relation(fields: [id_producto], references: [id])

  @@index([id_pedido])
  @@index([id_producto])
  @@index([id_estado])
  @@map("detalle_pedidos")
}

model pago {
  id               Int            @id @default(autoincrement())
  valor            Decimal        @db.Decimal(10, 2)
  id_administrador Int
  detalle_pago     detalle_pago[]
  administrador    administrador  @relation(fields: [id_administrador], references: [id])

  @@index([id_administrador])
  @@map("pago")
}

model detalle_pago {
  id         Int      @id @default(autoincrement())
  id_pago    Int
  id_pedido  Int
  valor      Decimal  @db.Decimal(10, 2)
  fecha_pago DateTime
  pago       pago     @relation(fields: [id_pago], references: [id], onDelete: Cascade)
  pedido     pedidos  @relation(fields: [id_pedido], references: [id], onDelete: Cascade)

  @@index([id_pago])
  @@index([id_pedido])
  @@index([fecha_pago])
  @@map("detalle_pago")
}

model auditoria {
  id           Int      @id @default(autoincrement())
  usuario      String   @db.VarChar(50)
  fecha_accion DateTime @default(now())
  accion       String   @db.VarChar(100)

  @@index([fecha_accion])
  @@index([usuario])
  @@map("auditoria")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model messages {
  id                  Int           @id @default(autoincrement())
  user_id             Int
  client_id           Int
  content             String
  direction           String        @db.VarChar(20)
  status              String        @db.VarChar(20)
  whatsapp_message_id String?       @db.VarChar(100)
  created_at          DateTime?     @default(now()) @db.Timestamptz(6)
  cliente             cliente       @relation(fields: [client_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_message_client")
  administrador       administrador @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_message_user")

  @@index([client_id], map: "idx_messages_client_id")
  @@index([created_at], map: "idx_messages_created_at")
  @@index([user_id], map: "idx_messages_user_id")
}

model whatsapp_sessions {
  id            Int           @id @default(autoincrement())
  user_id       Int           @unique
  session_data  Json
  phone_number  String?       @db.VarChar(20)
  connected_at  DateTime?     @default(now()) @db.Timestamptz(6)
  created_at    DateTime?     @default(now()) @db.Timestamptz(6)
  updated_at    DateTime?     @default(now()) @db.Timestamptz(6)
  administrador administrador @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_whatsapp_user")

  @@index([user_id], map: "idx_whatsapp_sessions_user_id")
}
