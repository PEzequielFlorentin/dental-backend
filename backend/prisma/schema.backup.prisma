// ==============================
// ENUMS
// ==============================
enum TipoCliente {
  ODONTOLOGO
  CLINICA_DENTAL
  OTRO
}

enum RolUsuario {
  ADMIN
  SUPER_ADMIN
}

// ==============================
// ADMINISTRADOR
// ==============================
model administrador {
  id                       Int      @id @default(autoincrement())
  nombre                   String   @db.VarChar(100)
  telefono                 String   @db.VarChar(20)
  email                    String   @db.VarChar(100) @unique
  usuario                  String   @db.VarChar(50) @unique
  super_usuario            Boolean  @default(false)
  password                 String   @db.Text
  two_factor_enabled       Boolean  @default(false)
  two_factor_secret        String?  @db.Text
  two_factor_backup_codes  Json?    @db.JsonB
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  activo                   Boolean  @default(true)
  refreshToken             String?  @db.Text
  resetPasswordToken       String?  @db.Text
  resetPasswordExpiry      DateTime?
  
  // Relaciones
  clientes      cliente[]
  productos     producto[]
  pedidos       pedidos[]
  pagos         pago[]
  otro_gastos   otro_gasto[] 

  @@index([email])
  @@index([usuario])
  @@index([activo])
  @@map("administrador")
}

// ==============================
// TIPO CLIENTE
// ==============================
model tipo_cliente {
  id           Int       @id @default(autoincrement())
  descripcion  String    @db.VarChar(50)
  fecha_insert DateTime? @default(now())
  fecha_delete DateTime?

  clientes    cliente[]

  @@map("tipo_cliente")
}

// ==============================
// CLIENTE
// ==============================
model cliente {
  id               Int          @id @default(autoincrement())
  nombre           String       @db.VarChar(100)
  telefono         String       @db.VarChar(20)
  email            String       @db.VarChar(100)
  id_administrador Int
  
  celular          String?      @db.VarChar(20)
  id_tipo          Int?

  administrador   administrador  @relation(fields: [id_administrador], references: [id])
  tipo_cliente    tipo_cliente?  @relation(fields: [id_tipo], references: [id], onDelete: SetNull)
  pedidos         pedidos[]

  @@index([id])
  @@index([id_administrador])
  @@index([nombre])
  @@index([telefono])
  @@index([id_tipo])
  @@unique([email])
  @@map("cliente")
}

// ==============================
// OTRO_GASTO
// ==============================
model otro_gasto {
  id               Int      @id @default(autoincrement())
  tipo             String   @db.VarChar(20)
  descripcion      String   @db.Text
  monto            Decimal  @db.Decimal(10, 2)
  fecha            DateTime @default(now()) @db.Timestamp
  id_administrador Int

  administrador    administrador @relation(fields: [id_administrador], references: [id], onDelete: Restrict)

  @@index([id])
  @@index([tipo])
  @@index([fecha])
  @@index([id_administrador])
  @@map("otro_gasto")
}

// ==============================
// PRODUCTO
// ==============================
model producto {
  id               Int      @id @default(autoincrement())
  tipo             String   @db.VarChar(100)
  id_administrador Int

  administrador    administrador @relation(fields: [id_administrador], references: [id], onDelete: Restrict)
  detalle_pedidos  detalle_pedidos[]

  @@index([id])
  @@index([id_administrador])
  @@index([tipo])
  @@map("producto")
}

// ==============================
// PEDIDOS
// ==============================
model pedidos {
  id               Int       @id @default(autoincrement())
  id_cliente       Int
  fecha_pedido     DateTime  @default(now()) @db.Timestamp
  fecha_entrega    DateTime  @db.Timestamp
  fecha_delete     DateTime? @db.Timestamp
  id_administrador Int
  descripcion      String?   @db.Text

  cliente        cliente         @relation(fields: [id_cliente], references: [id], onDelete: Cascade)
  administrador  administrador   @relation(fields: [id_administrador], references: [id], onDelete: Restrict)
  detalle_pedidos detalle_pedidos[]
  detalle_pago   detalle_pago[]

  @@index([id])
  @@index([id_cliente])
  @@index([id_administrador])
  @@index([fecha_pedido])
  @@index([fecha_entrega])
  @@index([fecha_delete])
  @@map("pedidos")
}

// ==============================
// ESTADO
// ==============================
model estado {
  id            Int       @id @default(autoincrement())
  descripcion   String    @db.VarChar(50) 
  fecha_insert  DateTime  @default(now()) @db.Timestamp
  fecha_delete  DateTime? @db.Timestamp

  detalle_pedidos detalle_pedidos[]

  @@index([id])
  @@index([fecha_delete])
  @@unique([descripcion])
  @@map("estado")
}

// ==============================
// DETALLE_PEDIDOS
// ==============================
model detalle_pedidos {
  id              Int      @id @default(autoincrement())
  id_pedido       Int
  id_producto     Int
  cantidad        Int
  precio_unitario Decimal  @db.Decimal(10, 2)
  paciente        String   @db.VarChar(100)
  id_estado       Int

  pedido    pedidos   @relation(fields: [id_pedido], references: [id], onDelete: Cascade)
  producto  producto  @relation(fields: [id_producto], references: [id], onDelete: Restrict)
  estado    estado    @relation(fields: [id_estado], references: [id], onDelete: Restrict)

  @@index([id])
  @@index([id_pedido])
  @@index([id_producto])
  @@index([id_estado])
  @@map("detalle_pedidos")
}

// ==============================
// PAGO
// ==============================
model pago {
  id               Int      @id @default(autoincrement())
  valor            Decimal  @db.Decimal(10, 2)
  id_administrador Int

  administrador administrador @relation(fields: [id_administrador], references: [id], onDelete: Restrict)
  detalle_pago  detalle_pago[]

  @@index([id])
  @@index([id_administrador])
  @@map("pago")
}

// ==============================
// DETALLE_PAGO
// ==============================
model detalle_pago {
  id         Int      @id @default(autoincrement())
  id_pago    Int
  id_pedido  Int
  valor      Decimal  @db.Decimal(10, 2)
  fecha_pago DateTime @db.Timestamp

  pago    pago    @relation(fields: [id_pago], references: [id], onDelete: Cascade)
  pedido  pedidos @relation(fields: [id_pedido], references: [id], onDelete: Cascade)

  @@index([id])
  @@index([id_pago])
  @@index([id_pedido])
  @@index([fecha_pago])
  @@map("detalle_pago")
}

// ==============================
// AUDITORIA
// ==============================
model auditoria {
  id           Int      @id @default(autoincrement())
  usuario      String   @db.VarChar(50)
  fecha_accion DateTime @default(now())
  accion       String   @db.VarChar(100)


  @@index([fecha_accion])
  @@index([usuario])
  @@map("auditoria")
}

// ==============================
// GENERATOR Y DATASOURCE
// ==============================
generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}