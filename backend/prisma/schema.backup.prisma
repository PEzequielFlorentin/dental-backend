// ==============================
// GENERATOR Y DATASOURCE
// ==============================
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==============================
// ADMINISTRADOR - TU TABLA + CAMPOS DE AUTENTICACIÓN
// ==============================
model administrador {
  id            Int      @id @default(autoincrement())
  nombre        String   @db.VarChar(100)
  telefono      String?  @db.VarChar(20)
  email         String?  @db.VarChar(100)  // Para login
  usuario       String   @db.VarChar(50) @unique
  super_usuario Boolean? @default(false)
  
  // 🔐 CAMPOS DE AUTENTICACIÓN (NUEVOS)
  password               String    @db.VarChar(255)      // Contraseña hasheada
  rol                    String    @default("ADMIN")     // ADMIN o SUPER_ADMIN
  reset_password_token   String?   @db.VarChar(255) @unique
  reset_password_expires DateTime?                         // Expiración del token
  created_at             DateTime  @default(now())        // Fecha de creación
  updated_at             DateTime  @updatedAt              // Última actualización
  last_login             DateTime?                         // Último ingreso
  login_attempts         Int       @default(0)             // Intentos fallidos
  locked_until           DateTime?                         // Bloqueo temporal

  // Relaciones (tus relaciones originales)
  clientes      cliente[]
  productos     producto[]
  pedidos       pedidos[]
  pagos         pago[]
  auditorias    auditoria[]
  tokens        reset_token[]      // Nueva relación

  @@index([email])
  @@index([usuario])
  @@map("administrador")
}

// ==============================
// TIPO CLIENTE - TU TABLA ORIGINAL
// ==============================
model tipo_cliente {
  id           Int       @id @default(autoincrement())
  descripcion  String    @db.VarChar(50)
  fecha_insert DateTime? @default(now())
  fecha_delete DateTime?

  clientes    cliente[]

  @@map("tipo_cliente")
}

// ==============================
// CLIENTE - TU TABLA ORIGINAL
// ==============================
model cliente {
  id               Int          @id @default(autoincrement())
  id_tipo          Int?
  nombre           String       @db.VarChar(100)
  telefono         String?      @db.VarChar(20)
  celular          String?      @db.VarChar(20)
  email            String?      @db.VarChar(100)
  id_administrador Int?

  // Relaciones
  administrador   administrador? @relation(fields: [id_administrador], references: [id])
  tipo_cliente    tipo_cliente?  @relation(fields: [id_tipo], references: [id])
  pedidos         pedidos[]

  @@index([id])
  @@map("cliente")
}

// ==============================
// PRODUCTO - TU TABLA ORIGINAL
// ==============================
model producto {
  id               Int      @id @default(autoincrement())
  tipo             String   @db.VarChar(50)
  valor            Decimal  @db.Decimal(10, 2)
  id_administrador Int?

  administrador    administrador? @relation(fields: [id_administrador], references: [id])
  detalle_pedidos  detalle_pedidos[]

  @@index([id])
  @@map("producto")
}

// ==============================
// PEDIDOS - TU TABLA ORIGINAL
// ==============================
model pedidos {
  id               Int       @id @default(autoincrement())
  id_cliente       Int
  fecha_entrega    DateTime? @db.Date
  fecha_pedido     DateTime  @db.Date
  fecha_delete     DateTime? @db.Date
  id_administrador Int?
  descripcion      String?   @db.VarChar(500)

  // Relaciones
  cliente        cliente         @relation(fields: [id_cliente], references: [id])
  administrador  administrador?  @relation(fields: [id_administrador], references: [id])
  detalle_pedidos detalle_pedidos[]
  detalle_pago   detalle_pago[]

  @@index([id])
  @@map("pedidos")
}

// ==============================
// ESTADO - TU TABLA ORIGINAL
// ==============================
model estado {
  id            Int       @id @default(autoincrement())
  descripcion   String    @db.VarChar(50)
  fecha_insert  DateTime? @default(now())
  fecha_delete  DateTime?

  detalle_pedidos detalle_pedidos[]

  @@index([id])
  @@map("estado")
}

// ==============================
// DETALLE_PEDIDOS - TU TABLA ORIGINAL
// ==============================
model detalle_pedidos {
  id              Int       @id @default(autoincrement())
  id_pedido       Int
  id_producto     Int
  cantidad        Int
  precio_unitario Decimal   @db.Decimal(10, 2)
  paciente        String?   @db.VarChar(100)
  id_estado       Int?

  // Relaciones
  pedido    pedidos   @relation(fields: [id_pedido], references: [id])
  producto  producto  @relation(fields: [id_producto], references: [id])
  estado    estado?   @relation(fields: [id_estado], references: [id])

  @@index([id])
  @@map("detalle_pedidos")
}

// ==============================
// PAGO - TU TABLA ORIGINAL
// ==============================
model pago {
  id               Int      @id @default(autoincrement())
  valor            Decimal  @db.Decimal(10, 2)
  id_administrador Int?

  administrador administrador? @relation(fields: [id_administrador], references: [id])
  detalle_pago  detalle_pago[]

  @@index([id])
  @@map("pago")
}

// ==============================
// DETALLE_PAGO - TU TABLA ORIGINAL
// ==============================
model detalle_pago {
  id         Int       @id @default(autoincrement())
  id_pago    Int
  id_pedido  Int
  valor      Decimal   @db.Decimal(10, 2)
  fecha_pago DateTime  @db.Date

  // Relaciones
  pago    pago    @relation(fields: [id_pago], references: [id])
  pedido  pedidos @relation(fields: [id_pedido], references: [id])

  @@index([id])
  @@map("detalle_pago")
}

// ==============================
// AUDITORIA - TU TABLA ORIGINAL + CAMPOS NUEVOS
// ==============================
model auditoria {
  id                 BigInt    @id @default(autoincrement())
  id_administrador   Int?                          // 🔐 NUEVO
  usuario            String    @db.VarChar(50)
  fecha_accion       DateTime  @default(now())
  accion             String    @db.VarChar(255)
  ip_address         String?   @db.VarChar(45)     // 🔐 NUEVO
  detalles           String?   @db.Text            // 🔐 NUEVO

  // Relaciones
  administrador      administrador? @relation(fields: [id_administrador], references: [id])

  @@index([fecha_accion])
  @@map("auditoria")
}

// ==============================
// RESET TOKEN - NUEVA TABLA PARA RECUPERACIÓN
// ==============================
model reset_token {
  id                 Int       @id @default(autoincrement())
  id_administrador   Int
  token              String    @db.VarChar(255) @unique
  tipo               String    @default("RESET_PASSWORD")
  expires_at         DateTime
  used_at            DateTime?
  created_at         DateTime  @default(now())
  ip_address         String?   @db.VarChar(45)

  // Relaciones
  administrador      administrador @relation(fields: [id_administrador], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([expires_at])
  @@map("reset_token")
}
